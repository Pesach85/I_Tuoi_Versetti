<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Libro con autocompletamento -->
    <AutoCompleteTextView
        android:id="@+id/batchLibro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Libro"
        android:inputType="textCapWords"
        android:imeOptions="actionNext"
        android:completionThreshold="1" />

    <!-- Capitolo iniziale -->
    <EditText
        android:id="@+id/batchCapitolo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Capitolo iniziale"
        android:inputType="number"
        android:imeOptions="actionNext" />

    <!-- Versetto iniziale -->
    <EditText
        android:id="@+id/batchVersettoIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Versetto iniziale"
        android:inputType="number"
        android:imeOptions="actionNext" />

    <!-- Versetto finale -->
    <EditText
        android:id="@+id/batchVersettoFin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Versetto finale"
        android:inputType="number"
        android:imeOptions="actionNext" />

    <!-- Numero iterazioni -->
    <EditText
        android:id="@+id/batchIterazioni"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Numero iterazioni"
        android:inputType="number"
        android:imeOptions="actionDone" />

    <!-- Bottoni affiancati -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/batchStartBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Avvia batch" />

        <Button
            android:id="@+id/batchStopBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Ferma"
            android:enabled="false" />

    </LinearLayout>

    <!-- Output scrollabile -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/batchOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#f5f5f5"
            android:fontFamily="monospace" />

    </ScrollView>

</LinearLayout>