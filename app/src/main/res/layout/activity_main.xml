<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/appbar"
            app:titleTextColor="@color/on_primary_container"
            app:layout_collapseMode="pin" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ricerca_biblica_per_versetti"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:letterSpacing="0.01"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sottotitolo_ricerca"
                android:textSize="14sp"
                android:textColor="@color/on_surface_variant"
                android:layout_marginBottom="14dp"/>

            <!-- Argomento (modalità alternativa) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:hint="@string/argomento_biblico_hint">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoCompleteTextViewTopic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchSemanticSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:checked="true"
                android:text="@string/ricerca_ai_semantica"/>

            <!-- Libro -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:hint="@string/libro_biblico">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoCompleteTextView"
                    android:layout_width="match_parent"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:imeOptions="actionNext"
                    android:completionThreshold="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Capitolo -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:hint="@string/inserisci_il_capitolo">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoCompleteTextView2"
                    android:layout_width="match_parent"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Versetto iniziale -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:hint="@string/versetto_iniziale">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoCompleteTextView3"
                    android:layout_width="match_parent"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:imeOptions="actionNext"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Versetto finale -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/field_spacing"
                android:hint="@string/versetto_finale_facoltativo">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoCompleteTextView4"
                    android:layout_width="match_parent"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:imeOptions="actionDone"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/cerca"/>

            <!-- Risultato -->
            <!-- Risultato -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cardUseCompatPadding="true">
            
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
            
                    <!-- Header card con icona libro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:background="@color/primary_container">
            
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_menu_book"
                            app:tint="@color/on_primary_container"
                            android:contentDescription="@null"/>
            
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/risultato_della_ricerca"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true"
                            android:textColor="@color/on_primary_container"/>
            
                    </LinearLayout>
            
                    <!-- Testo versetto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
            
                        <!-- Virgoletta decorativa -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\u201C"
                            android:textSize="48sp"
                            android:textColor="@color/primary"
                            android:alpha="0.25"
                            android:fontFamily="serif"
                            android:lineSpacingExtra="0dp"
                            android:includeFontPadding="false"
                            android:layout_marginTop="-8dp"
                            android:layout_marginEnd="4dp"/>
            
                        <MultiAutoCompleteTextView
                            android:id="@+id/multiAutoCompleteTextView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="100dp"
                            android:hint="@string/risultato_della_ricerca"
                            android:fontFamily="serif"
                            android:textIsSelectable="true"
                            android:focusable="false"
                            android:clickable="false"
                            android:longClickable="false"
                            android:scrollbars="vertical"
                            android:textSize="18sp"
                            android:lineSpacingExtra="5dp"
                            android:letterSpacing="0.01"
                            android:gravity="start|top"
                            android:textColor="@color/on_background"/>
            
                    </LinearLayout>
            
                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/outline"
                        android:alpha="0.3"/>
            
                    <!-- Azioni -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:gravity="center">
            
                        <!-- Condividi WhatsApp -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/imageButton"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="Condividi su WhatsApp"
                            app:icon="@mipmap/pngitem_1485047"
                            app:iconSize="28dp"/>
            
                        <!-- Copia testo -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopy"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="Copia testo"
                            app:icon="@drawable/ic_content_copy"
                            app:iconSize="24dp"/>
            
                        <!-- Genera immagine artistica -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGenerateImage"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="Genera immagine"
                            app:icon="@drawable/ic_palette"
                            app:iconSize="24dp"/>
            
                        <!-- Condividi generico -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnShare"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="Condividi"
                            app:icon="@drawable/ic_share"
                            app:iconSize="24dp"/>
            
                        <!-- Salva preferiti -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFavorite"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="Salva nei preferiti"
                            app:icon="@drawable/ic_bookmark_border"
                            app:iconSize="24dp"/>
            
                    </LinearLayout>
            
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Avvertenze -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="@dimen/corner_radius"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/note_legali"
                    android:textSize="13sp"
                    android:padding="12dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
